projection;
//strict ( 2 );
use draft;

define behavior for ZC_PR_Header //alias <alias_name>
{
  use create;
  use update;
  use delete;
  use action Edit;
  use action Activate;
  use action Discard;
  use action Resume;
  use action Prepare;

  use association _pr_items { create; }

}

define behavior for ZC_PR_Item //alias <alias_name>
{
  use update;
  use delete;

  use association _pr_header;

}